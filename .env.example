# ==========================================
# Kampung Siber Retro — Environment Template
# Copy to your local env file for development.
# NEVER commit the real local env file (Rule 35 Security Guard).
# ==========================================

# Supabase public project URL (browser-exposed). Required for auth + DB.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (browser-exposed, RLS-protected).
NEXT_PUBLIC_SUPABASE_KEY=your-anon-public-key

# Supabase service role key (server-only, bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# Cloudflare R2 Storage (Rule 30 — 25MB total / 2MB per file / WebP 80-85%)
# Supply real credentials before production deploy. Keep secret.
# ==========================================
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket-name
